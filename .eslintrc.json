{
  "root": true,
  "env": { "browser": true, "es2022": true },
  "parserOptions": { "ecmaVersion": 2022, "sourceType": "module" },
  "extends": "eslint:recommended",
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "error",
    "eqeqeq": ["warn", "smart"],
    "prefer-const": "warn",
    "no-var": "error"
  },
  "ignorePatterns": ["**/*.test.js"]
}
